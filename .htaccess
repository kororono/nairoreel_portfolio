RewriteEngine On
RewriteBase /

# 0. Redirect www → non-www
RewriteCond %{HTTP_HOST} ^www\.nairoreelproductions\.com$ [NC]
RewriteRule ^ https://nairoreelproductions.com%{REQUEST_URI} [R=301,L]

# 1. Redirect /index or /index.html to / (canonical root)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index(\.html)?[\s?] [NC]
RewriteRule ^index(\.html)?$ / [R=301,L]

# 2. Redirect /home to / (canonical root)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /home[\s?] [NC]
RewriteRule ^home$ / [R=301,L]

# 3. Redirect other .html URLs to clean URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Internally rewrite other clean URLs to .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
